  },
  {
    "id": "fn_status_text",
    "type": "function",
    "z": "flow_home_panel",
    "name": "格式化在线状态",
    "func": "msg.payload = (msg.payload === 'online') ? '在线' : '离线'; return msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 200,
    "wires": [
      [
        "ui_text_status"
      ]
    ]
  },
  {
    "id": "mqtt_in_switch_state",
    "type": "mqtt in",
    "z": "flow_home_panel",
    "name": "订阅开关状态",
    "topic": "home/room1/env01/switch/state",
    "qos": "1",
    "datatype": "utf8",
    "broker": "mqtt_broker_home",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 160,
    "y": 260,
    "wires": [
      [
        "fn_switch_text"
      ]
    ]
  },
  {
    "id": "fn_switch_text",
    "type": "function",
    "z": "flow_home_panel",
    "name": "格式化开关状态",
    "func": "msg.payload = (msg.payload === 'ON') ? '已打开' : '已关闭'; return msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 260,
    "wires": [
