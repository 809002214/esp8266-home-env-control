  {
    "id": "mqtt_in_system_state",
    "type": "mqtt in",
    "z": "flow_home_panel",
    "name": "订阅系统状态",
    "topic": "home/room1/env01/system/state",
    "qos": "1",
    "datatype": "json",
    "broker": "mqtt_broker_home",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 160,
    "y": 500,
    "wires": [
      [
        "fn_split_system_state"
      ]
    ]
  },
  {
    "id": "fn_split_system_state",
    "type": "function",
    "z": "flow_home_panel",
    "name": "拆分系统状态",
    "func": "var data = msg.payload || {}; var wifi = { payload: Number.isFinite(Number(data.wifi_rssi)) ? (String(data.wifi_rssi) + ' dBm') : '--' }; var uptimeSec = Number(data.uptime_sec || 0); var uptimeHour = (uptimeSec / 3600).toFixed(1); var uptime = { payload: uptimeHour + ' 小时' }; var ip = { payload: data.ip || '--' }; var timeText = data.local_time ? (data.local_time + (data.time_synced ? '' : ' (校时中)')) : '时间同步中'; var time = { payload: timeText }; var error = { payload: data.last_error || 'OK' }; return [wifi, uptime, ip, time, error];",
    "outputs": 5,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 500,
    "wires": [
      [
        "ui_text_wifi"
      ],
      [
        "ui_text_uptime"
      ],
      [
        "ui_text_ip"
      ],
      [
        "ui_text_time"
      ],
      [
        "ui_text_error"
      ]
    ]
  },
  {
    "id": "mqtt_in_device_info",
    "type": "mqtt in",
    "z": "flow_home_panel",
    "name": "订阅设备信息",
    "topic": "home/room1/env01/device/info",
    "qos": "1",
    "datatype": "json",
    "broker": "mqtt_broker_home",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 160,
    "y": 740,
