    "acceptsClientConfig": [
      "ui-notification",
      "ui-control",
      "ui-template",
      "ui-text",
      "ui-button",
      "ui-chart"
    ],
    "showPathInSidebar": false,
    "headerContent": "page",
    "navigationStyle": "temporary",
    "titleBarStyle": "default",
    "showReconnectNotification": true,
    "notificationDisplayTime": 3,
    "showDisconnectNotification": true,
    "allowInstall": false
