  {
    "id": "mqtt_in_temperature",
    "type": "mqtt in",
    "z": "flow_home_panel",
    "name": "订阅温度",
    "topic": "home/room1/env01/temperature",
    "qos": "1",
    "datatype": "auto-detect",
    "broker": "mqtt_broker_home",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 140,
    "y": 220,
    "wires": [
      [
        "fn_temperature_split"
      ]
    ]
  },
  {
    "id": "fn_temperature_split",
    "type": "function",
    "z": "flow_home_panel",
    "name": "温度卡片和曲线",
    "func": "var value = Number(msg.payload); var display = { payload: Number.isFinite(value) ? (value.toFixed(1) + ' °C') : '--' }; var chart = null; if (Number.isFinite(value)) { var rounded = Math.round(value * 10) / 10; var last = context.get('lastChart'); if (typeof last !== 'number' || Math.abs(rounded - last) >= 0.1) { context.set('lastChart', rounded); chart = { payload: rounded, topic: '温度' }; } } return [display, chart];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 420,
    "y": 220,
    "wires": [
      [
        "ui_tpl_temperature_card"
      ],
      [
        "ui_chart_temperature"
      ]
    ]
  },
