      ]
    ]
  },
  {
    "id": "fn_firmware_text",
    "type": "function",
    "z": "flow_home_panel",
    "name": "格式化固件版本",
    "func": "var data = msg.payload || {}; var version = data.firmware_version || '--'; var model = data.model || 'ESP8266_ENV_MONITOR'; msg.payload = model + ' / ' + version; return msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 740,
    "wires": [
      [
        "ui_text_firmware"
      ]
    ]
  },
