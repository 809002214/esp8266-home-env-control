  {
    "id": "mqtt_in_temperature",
    "type": "mqtt in",
    "z": "flow_home_panel",
    "name": "订阅温度",
    "topic": "home/room1/env01/temperature",
    "qos": "1",
    "datatype": "auto-detect",
    "broker": "mqtt_broker_home",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 150,
    "y": 80,
    "wires": [
      [
        "fn_temperature_text"
      ]
    ]
  },
  {
    "id": "fn_temperature_text",
    "type": "function",
    "z": "flow_home_panel",
    "name": "格式化温度",
    "func": "var value = Number(msg.payload); msg.payload = Number.isFinite(value) ? (value.toFixed(1) + ' °C') : '--'; return msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 420,
    "y": 80,
    "wires": [
      [
        "ui_text_temperature"
      ]
    ]
  },
  {
    "id": "mqtt_in_humidity",
    "type": "mqtt in",
    "z": "flow_home_panel",
    "name": "订阅湿度",
    "topic": "home/room1/env01/humidity",
    "qos": "1",
