    "z": "flow_home_panel",
    "name": "订阅在线状态",
    "topic": "home/room1/env01/status",
    "qos": "1",
    "datatype": "utf8",
    "broker": "mqtt_broker_home",
    "nl": false,
    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 160,
    "y": 200,
