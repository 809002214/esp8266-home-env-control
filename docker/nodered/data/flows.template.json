    "rap": true,
    "rh": 1,
    "inputs": 0,
    "x": 150,
    "y": 140,
    "wires": [
      [
        "fn_humidity_text"
      ]
    ]
  },
  {
    "id": "fn_humidity_text",
    "type": "function",
    "z": "flow_home_panel",
    "name": "格式化湿度",
    "func": "var value = Number(msg.payload); msg.payload = Number.isFinite(value) ? (value.toFixed(0) + ' %') : '--'; return msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 420,
