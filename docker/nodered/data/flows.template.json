[
  {
    "id": "flow_home_panel",
    "type": "tab",
    "label": "家庭智能面板",
    "disabled": false,
    "info": "ESP8266 温湿度与远程控制看板"
  },
  {
    "id": "mqtt_broker_home",
    "type": "mqtt-broker",
    "name": "家庭 MQTT",
    "broker": "__MQTT_BROKER__",
    "port": "__MQTT_PORT__",
    "clientid": "nodered-home-panel",
    "autoConnect": true,
    "usetls": false,
    "protocolVersion": "4",
    "keepalive": "60",
    "cleansession": true,
    "birthTopic": "nodered/home/status",
    "birthQos": "0",
    "birthPayload": "online",
    "closeTopic": "nodered/home/status",
    "closeQos": "0",
    "closePayload": "offline",
    "willTopic": "nodered/home/status",
    "willQos": "0",
    "willPayload": "offline",
    "user": "__MQTT_USERNAME__",
    "password": "__MQTT_PASSWORD__"
  },
  {
    "id": "ui_base_main",
    "type": "ui-base",
    "name": "家庭智能面板",
    "path": "/dashboard",
    "appIcon": "home-thermometer-outline",
    "includeClientData": true,
    "acceptsClientConfig": [
      "ui-notification",
      "ui-control",
      "ui-template",
      "ui-text",
      "ui-button"
    ],
    "showPathInSidebar": false,
    "headerContent": "page",
    "navigationStyle": "temporary",
    "titleBarStyle": "default",
    "showReconnectNotification": true,
    "notificationDisplayTime": 3,
    "showDisconnectNotification": true,
    "allowInstall": false
  },
  {
    "id": "ui_theme_main",
    "type": "ui-theme",
    "name": "暖白仪表盘",
