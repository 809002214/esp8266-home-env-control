  {
    "id": "ui_tpl_site_style",
    "type": "ui-template",
    "z": "flow_home_panel",
    "group": "",
    "page": "",
    "ui": "ui_base_main",
    "name": "站点样式",
    "order": 0,
    "width": 0,
    "height": 0,
    "head": "",
    "format": ":root {\n  --panel-ink: #16313c;\n  --panel-muted: #6d7f86;\n  --panel-border: rgba(255,255,255,0.58);\n}\nbody,\n.nrdb-ui-theme {\n  font-family: \"Segoe UI\", \"Microsoft YaHei\", \"PingFang SC\", \"Noto Sans SC\", sans-serif;\n  color: var(--panel-ink);\n}\n.nrdb-ui-page {\n  background:\n    radial-gradient(circle at 0% 0%, rgba(231, 111, 81, 0.24), transparent 30%),\n    radial-gradient(circle at 100% 10%, rgba(31, 102, 114, 0.20), transparent 28%),\n    linear-gradient(180deg, #f3eadf 0%, #edf2f1 100%);\n  min-height: 100vh;\n}\n.v-toolbar {\n  background: rgba(23, 39, 45, 0.80) !important;\n  backdrop-filter: blur(16px);\n}\n.hero-group .v-card,\n.metric-group .v-card,\n.trend-group .v-card,\n.system-group .v-card,\n.control-group .v-card,\n.firmware-group .v-card {\n  border-radius: 24px !important;\n  border: 1px solid var(--panel-border) !important;\n  box-shadow: 0 22px 55px rgba(24, 42, 47, 0.10) !important;\n  backdrop-filter: blur(10px);\n}\n.hero-group .v-card {\n  background: linear-gradient(135deg, #173249 0%, #245f6d 55%, #de7c47 120%) !important;\n  color: #ffffff !important;\n  border: none !important;\n}\n.metric-group .v-card,\n.trend-group .v-card,\n.system-group .v-card,\n.control-group .v-card,\n.firmware-group .v-card {\n  background: rgba(255, 250, 244, 0.84) !important;\n}\n.hero-banner {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 20px;\n  padding: 10px 6px;\n}\n.hero-banner h2 {\n  margin: 8px 0 10px;\n  font-size: clamp(28px, 4vw, 38px);\n  line-height: 1.1;\n}\n.hero-banner p {\n  margin: 0;\n  max-width: 680px;\n  color: rgba(255, 255, 255, 0.88);\n}\n.hero-eyebrow {\n  display: inline-flex;\n  padding: 8px 12px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.12);\n  font-size: 12px;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n}\n.hero-chip {\n  padding: 14px 18px;\n  border-radius: 20px;\n  background: rgba(255, 255, 255, 0.14);\n  color: #fff7ef;\n  font-weight: 700;\n  white-space: nowrap;\n}\n.metric-group .nrdb-ui-widget,\n.metric-group .nrdb-ui-widget > div,\n.metric-group .v-card,\n.metric-group .v-card-text,\n.metric-group .v-card-text > div {\n  overflow: hidden !important;\n  scrollbar-width: none !important;\n  -ms-overflow-style: none !important;\n}\n.metric-group .nrdb-ui-widget::-webkit-scrollbar,\n.metric-group .nrdb-ui-widget > div::-webkit-scrollbar,\n.metric-group .v-card::-webkit-scrollbar,\n.metric-group .v-card-text::-webkit-scrollbar,\n.metric-group .v-card-text > div::-webkit-scrollbar {\n  width: 0 !important;\n  height: 0 !important;\n  display: none !important;\n}\n.metric-shell {\n  min-height: 122px;\n  height: 100%;\n  padding: 16px;\n  border-radius: 20px;\n  overflow: hidden;\n  background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(249,244,236,0.88));\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n}\n.metric-label {\n  font-size: 13px;\n  font-weight: 700;\n  letter-spacing: 0.04em;\n  color: var(--panel-muted);\n}\n.metric-value {\n  font-size: clamp(26px, 3.2vw, 36px);\n  line-height: 1;\n  font-weight: 800;\n}\n.metric-note {\n  font-size: 12px;\n  color: #7b8b91;\n}\n.metric-temp .metric-value { color: #d65f35; }\n.metric-humidity .metric-value { color: #247e8b; }\n.metric-status .metric-value { color: #2c6670; }\n.metric-switch .metric-value { color: #8b6a2b; }\n.chart-card .v-card {\n  overflow: hidden;\n}\n.detail-item .v-card {\n  background: rgba(255,255,255,0.66) !important;\n  box-shadow: none !important;\n}\n.control-note,\n.firmware-note {\n  padding: 18px;\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(31, 102, 114, 0.08), rgba(222, 124, 71, 0.08));\n  color: #42575f;\n  font-size: 13px;\n  line-height: 1.65;\n}\n.action-btn .v-btn {\n  min-height: 48px !important;\n  border-radius: 16px !important;\n  text-transform: none !important;\n  font-weight: 700 !important;\n  box-shadow: 0 12px 28px rgba(27, 38, 42, 0.12) !important;\n}\n.action-on .v-btn { background: linear-gradient(135deg, #2c9b72, #256b52) !important; }\n.action-off .v-btn { background: linear-gradient(135deg, #b95555, #8d3737) !important; }\n.action-restart .v-btn { background: linear-gradient(135deg, #d48d2f, #b56d17) !important; }\n.action-reset .v-btn { background: linear-gradient(135deg, #5f58b8, #3c3991) !important; }\n.action-upgrade .v-btn { background: linear-gradient(135deg, #245f6d, #173249) !important; }\n@media (max-width: 760px) {\n  .hero-banner {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n  .hero-chip {\n    white-space: normal;\n  }\n}",
    "storeOutMessages": true,
    "passthru": true,
    "resendOnRefresh": true,
    "templateScope": "site:style",
    "className": "",
    "x": 140,
    "y": 40,
    "wires": [
      []
    ]
  },
