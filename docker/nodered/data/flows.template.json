    "name": "准备固件上传与目录",
    "func": "function sanitizeName(input, fallback) { var text = (input || '').toString().trim(); text = text.replace(/[^0-9A-Za-z._-]/g, '-'); text = text.replace(/-+/g, '-').replace(/^[-.]+|[-.]+$/g, ''); return text || fallback; } var file = msg.file || {}; var payload = msg.payload; if (Array.isArray(payload) && payload.length > 0) { payload = payload[0]; } if (payload && payload.type === 'Buffer' && Array.isArray(payload.data)) { payload = Buffer.from(payload.data); } if (!Buffer.isBuffer(payload)) { node.error('上传内容不是二进制 Buffer'); return [null, null, null, null, null, { payload: '上传失败：固件内容格式不正确' }]; } var originalName = sanitizeName(file.name || 'firmware.bin', 'firmware.bin'); if (!/\\.bin$/i.test(originalName)) { return [null, null, null, null, null, { payload: '上传失败：只允许 .bin 固件文件' }]; } var parsedVersion = ''; var versionMatch = originalName.match(/v\\d+\\.\\d+\\.\\d+/i); if (versionMatch) { parsedVersion = versionMatch[0].toLowerCase(); } var draftVersion = sanitizeName(flow.get('draftReleaseVersion') || parsedVersion || ('v' + new Date().toISOString().slice(0, 10).replace(/-/g, '.')), 'v1.0.0'); var releaseNote = (flow.get('draftReleaseNote') || '').toString().trim() || '网页上传'; var releaseDir = '/firmware/releases/' + draftVersion; var relativePath = releaseDir + '/' + originalName; var binaryMsg = { filename: '/data/public' + relativePath, payload: payload }; var noteLines = ['# ' + draftVersion, '', '- 文件名：`' + originalName + '`', '- 上传时间：' + new Date().toISOString(), '- 文件大小：' + String(file.size || payload.length) + ' 字节', '', '## 发布说明', '', releaseNote, '']; var noteMsg = { filename: '/data/public' + releaseDir + '/release.md', payload: noteLines.join('\\n') }; var catalog = flow.get('firmwareCatalog'); if (!Array.isArray(catalog)) { catalog = []; } var label = draftVersion + ' | ' + releaseNote; var entry = { label: label, value: relativePath, version: draftVersion, filename: originalName, note: releaseNote, uploadedAt: new Date().toISOString() }; catalog = catalog.filter(function(item) { return item && item.value !== relativePath; }); catalog.unshift(entry); flow.set('firmwareCatalog', catalog); var manifestMsg = { filename: '/data/public/firmware/catalog.json', payload: JSON.stringify(catalog, null, 2) }; var dropdownMsg = { ui_update: { options: catalog.map(function(item) { return { label: item.label, value: item.value }; }) } }; var selectedMsg = { payload: relativePath }; var statusMsg = { payload: '已上传 ' + originalName + '，发布版本 ' + draftVersion + ' 已加入可升级列表' }; return [binaryMsg, noteMsg, manifestMsg, dropdownMsg, selectedMsg, statusMsg];",
