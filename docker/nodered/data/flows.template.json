  {
    "id": "fn_build_weather_url",
    "type": "function",
    "z": "flow_home_panel",
    "name": "构建天气请求URL",
    "func": "var lat = flow.get('weather_lat');\nvar lon = flow.get('weather_lon');\nif (lat === undefined || lat === null || lat === '') { lat = 30.5728; }\nif (lon === undefined || lon === null || lon === '') { lon = 104.0668; }\nvar endpoint = 'https://api.open-meteo.com/v1/forecast';\nmsg.url = endpoint + '?latitude=' + lat + '&longitude=' + lon + '&current_weather=true&daily=temperature_2m_max,temperature_2m_min&timezone=auto';\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 430,
    "y": 1820,
    "wires": [
      [
        "http_weather_api"
      ]
    ]
  },
  {
    "id": "http_weather_api",
    "type": "http request",
    "z": "flow_home_panel",
    "name": "获取天气(Open-Meteo)",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": false,
    "headers": [],
    "x": 760,
    "y": 1820,
    "wires": [
      [
        "fn_map_weather_payload"
      ]
    ]
  },
  {
    "id": "fn_map_weather_payload",
    "type": "function",
    "z": "flow_home_panel",
    "name": "映射天气并发布MQTT",
    "func": "var body = msg.payload || {};\nif (!body.current_weather || !body.daily) {\n  return null;\n}\n\nvar code = Number(body.current_weather.weathercode);\nvar weatherText = '未知';\nvar weatherIcon = 'cloudy';\n\nif (code === 0) { weatherText = '晴'; weatherIcon = 'sunny'; }\nelse if (code >= 1 && code <= 3) { weatherText = '多云'; weatherIcon = 'cloudy'; }\nelse if (code === 45 || code === 48) { weatherText = '雾'; weatherIcon = 'fog'; }\nelse if ((code >= 51 && code <= 67) || (code >= 80 && code <= 82)) { weatherText = '雨'; weatherIcon = 'rainy'; }\nelse if ((code >= 71 && code <= 77) || code === 85 || code === 86) { weatherText = '雪'; weatherIcon = 'snow'; }\nelse if (code >= 95) { weatherText = '雷雨'; weatherIcon = 'storm'; }\n\nvar maxList = body.daily.temperature_2m_max || [];\nvar minList = body.daily.temperature_2m_min || [];\nvar temp = Math.round(Number(body.current_weather.temperature));\nvar high = maxList.length > 0 ? Math.round(Number(maxList[0])) : temp;\nvar low = minList.length > 0 ? Math.round(Number(minList[0])) : temp;\n\nvar weatherPayload = {\n  icon: weatherIcon,\n  temp: temp,\n  high: high,\n  low: low,\n  text: weatherText\n};\n\nmsg.topic = 'home/room1/env01/weather/state';\nmsg.payload = JSON.stringify(weatherPayload);\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1040,
    "y": 1820,
    "wires": [
      [
        "mqtt_out_weather"
      ]
    ]
  },
